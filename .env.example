# Bayou OTA - Mẫu file cấu hình môi trường
# Copy thành .env (đã có trong .gitignore) và điền key thật.

# RapidAPI key cho Skyscanner Flights Travel API.
# Đăng ký tại: https://rapidapi.com/DataCrawler/api/skyscanner-flights-travel-api
# Sau khi rotate key cũ (nếu đã commit nhầm), dán key MỚI vào đây.
RAPIDAPI_KEY=

# Tuỳ chọn: tên alternative cho cùng key (cả 2 đều được nhận).
# SKYSCANNER_RAPIDAPI_KEY=

# Database (nếu dùng app/Modules/* và legacy/api-bayou/*).
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=bayou_ota
# DB_USER=
# DB_PASS=
